# Required
TARGET_WALLET=0xTARGET_WALLET_TO_COPY
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
RPC_URL=https://YOUR_ENDPOINT_NAME.quiknode.pro/YOUR_KEY
# Optional builder attribution code (bytes32-style hex from Polymarket Builder Profile)
POLY_BUILDER_CODE=

# Trading
COPY_SELLS=true
POSITION_MULTIPLIER=0.1
MAX_TRADE_SIZE=100
MIN_TRADE_SIZE=1
SLIPPAGE_TOLERANCE=0.02
ORDER_TYPE=FOK

# Run until first SELL is copied, then exit (for validation)
EXIT_AFTER_FIRST_SELL_COPY=false

# Risk (0 disables the cap)
MAX_SESSION_NOTIONAL=0
MAX_PER_MARKET_NOTIONAL=0

# Monitoring
USE_WEBSOCKET=true
USE_USER_CHANNEL=false
POLL_INTERVAL=2000
WS_ASSET_IDS=
WS_MARKET_IDS=

# Optional gas floor overrides for Polygon approval/order txs
MIN_PRIORITY_FEE_GWEI=30
MIN_MAX_FEE_GWEI=60

# Startup retry delay in milliseconds when env/init fails
INIT_RETRY_MS=30000
